{
  "name": "@avgcxr/root",
  "version": "1.0.0",
  "private": true,
  "description": "Tamil Nadu AVGC-XR Portal - Animation, VFX, Gaming, Comics & Extended Reality",
  "license": "UNLICENSED",
  "scripts": {
    "start:dev": "concurrently \"nx serve public-portal\" \"nx serve applicant-portal\" \"nx serve admin-portal\"",
    "build:all": "nx run-many --target=build --all",
    "test:all": "nx run-many --target=test --all",
    "lint:all": "nx run-many --target=lint --all",
    "affected:build": "nx affected --target=build",
    "affected:test": "nx affected --target=test",
    "affected:lint": "nx affected --target=lint",
    "format:check": "prettier --check \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "format:write": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "scan:vulns": "osv-scanner --recursive .",
    "scan:fe": "osv-scanner -L pnpm-lock.yaml",
    "scan:java": "osv-scanner -L apps/api/pom.xml"
  },
  "devDependencies": {
    "nx": "^20.3.0",
    "@nx/angular": "^20.3.0",
    "@nx/eslint": "^20.3.0",
    "@nx/eslint-plugin": "^20.3.0",
    "@nx/jest": "^20.3.0",
    "@nx/js": "^23.0.1",
    "@nx/workspace": "^20.3.0",
    "@angular/animations": "^19.2.0",
    "@angular/cdk": "^19.2.0",
    "@angular/cli": "^19.2.0",
    "@angular/common": "^19.2.0",
    "@angular/compiler": "^19.2.0",
    "@angular/compiler-cli": "^19.2.0",
    "@angular/core": "^19.2.0",
    "@angular/forms": "^19.2.0",
    "@angular/language-service": "^19.2.0",
    "@angular/material": "^19.2.0",
    "@angular/platform-browser": "^19.2.0",
    "@angular/platform-browser-dynamic": "^19.2.0",
    "@angular/platform-server": "^19.2.0",
    "@angular/router": "^19.2.0",
    "@angular/ssr": "^19.2.0",
    "@ngx-translate/core": "^16.0.4",
    "@ngx-translate/http-loader": "^16.0.1",
    "echarts": "^5.5.1",
    "ngx-echarts": "^19.0.0",
    "rxjs": "~7.8.1",
    "tslib": "^2.6.3",
    "typescript": "~5.6.3",
    "zone.js": "~0.15.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@angular-eslint/eslint-plugin": "^19.0.0",
    "prettier": "^3.3.3",
    "concurrently": "^8.2.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "@types/jest": "^29.5.14",
    "playwright": "^1.46.0",
    "@playwright/test": "^1.46.0",
    "ng-packagr": "^19.2.0",
    "postcss": "^8.4.41",
    "postcss-import": "^16.1.0",
    "postcss-preset-env": "^9.6.0",
    "postcss-url": "^10.1.3",
    "@angular-devkit/build-angular": "^19.2.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.18.0",
    "pnpm": ">=9.0.0"
  }
}
