{
  "name": "@avgcxr/root",
  "version": "1.0.0",
  "private": true,
  "description": "Tamil Nadu AVGC-XR Portal - Animation, VFX, Gaming, Comics & Extended Reality",
  "license": "UNLICENSED",
  "scripts": {
    "start:dev": "concurrently \"nx serve public-portal\" \"nx serve applicant-portal\" \"nx serve admin-portal\"",
    "build:all": "nx run-many --target=build --all",
    "test:all": "nx run-many --target=test --all",
    "lint:all": "nx run-many --target=lint --all",
    "affected:build": "nx affected --target=build",
    "affected:test": "nx affected --target=test",
    "affected:lint": "nx affected --target=lint",
    "format:check": "prettier --check \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "format:write": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\""
  },
