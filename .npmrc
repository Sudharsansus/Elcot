node-linker=hoisted
confirm-modules-purge=false
strict-peer-dependencies=false

# Dependency overrides live in package.json "pnpm.overrides" — the single,
# working source of truth. pnpm 9.15 still honours that field (the deprecation
# warning it prints is cosmetic; `--frozen-lockfile` validates the lockfile's
# overrides against it and passes).
#
# The "override.*" keys that used to be here were REMOVED during the P0
# config-integrity pass because pnpm does not read overrides from .npmrc — they
# were never applied. Proof: the committed lockfile's `overrides:` block carried
# package.json's 13 entries (incl. @angular-devkit/build-angular), not the 12
# listed in this file. See docs/REMEDIATION-ROADMAP.md.
#
# Forward migration (roadmap P2): pnpm 10 drops the package.json "pnpm" field;
# move overrides into pnpm-workspace.yaml `overrides:` during the next real
# `pnpm install`, which can regenerate the lockfile against the real registry.
# (Attempted here and reverted — offline regeneration drops override targets
# absent from the local store, e.g. @casl/ability@6.7.5.)
