node-linker=hoisted
confirm-modules-purge=false
strict-peer-dependencies=false

# Transitive dependency overrides for security CVE remediation.
# pnpm 9 deprecated the package.json "pnpm.overrides" field; the
# overrides are read from this file via the "override.*" keys.
# See https://pnpm.io/settings#override for syntax.
override.@casl/ability=6.7.5
override.axios=1.16.0
override.tar=7.5.11
override.undici=6.27.0
override.minimatch=9.0.7
override.picomatch=4.0.4
override.lodash=4.18.0
override.serialize-javascript=7.0.3
override.js-cookie=3.0.7
override.tmp=0.2.7
override.ws=8.21.0
override.piscina=4.9.3
