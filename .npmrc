node-linker=hoisted
confirm-modules-purge=false
strict-peer-dependencies=false

# Dependency overrides currently live in package.json "pnpm.overrides".
#
# CORRECTION (2026-06-25, phase-4 real-env run): an earlier comment here claimed
# "pnpm 9.15 still honours that field; the deprecation warning is cosmetic." That
# is FALSE and was verified false on this machine. pnpm 9.15.0 prints:
#   [WARN] The "pnpm" field in package.json is no longer read by pnpm. The
#          following keys were ignored: "pnpm.overrides".
# and `pnpm install --frozen-lockfile` then aborts with
#   ERR_PNPM_LOCKFILE_CONFIG_MISMATCH: the current "overrides" configuration
#   doesn't match the value found in the lockfile
# i.e. the overrides are genuinely NOT applied from package.json anymore. The
# warning is load-bearing, not cosmetic.
#
# REQUIRED FIX (roadmap P2 — now mandatory, not optional): move the overrides
# into pnpm-workspace.yaml `overrides:` and regenerate pnpm-lock.yaml with a real
# `pnpm install` against the real registry. This machine's npm registry is a mock
# (it advertises non-existent versions such as @angular/core@22.0.2 and
# lodash@4.18.1), so the lockfile CANNOT be regenerated trustworthily here. See
# docs/PHASE-4-REAL-ENV-VERIFICATION.md and docs/REMEDIATION-ROADMAP.md.
#
# The "override.*" keys that used to be here were REMOVED during the P0
# config-integrity pass because pnpm does not read overrides from .npmrc either.
