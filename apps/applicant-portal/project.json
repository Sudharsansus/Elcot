{
  "name": "applicant-portal",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/applicant-portal/src",
  "tags": ["scope:public", "type:app"],
  "targets": {
    "build": {
      "executor": "@nx/angular:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/applicant-portal",
        "index": "apps/applicant-portal/src/index.html",
        "browser": "apps/applicant-portal/src/main.ts",
        "polyfills": ["zone.js"],
        "tsConfig": "apps/applicant-portal/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          "apps/applicant-portal/src/favicon.ico",
          "apps/applicant-portal/src/assets/i18n",
          "apps/applicant-portal/src/assets/images",
          "apps/applicant-portal/src/assets/fonts"
        ],
        "styles": ["apps/applicant-portal/src/styles.scss"],
        "scripts": [],
        "server": "apps/applicant-portal/src/main.server.ts",
        "stylePreprocessorOptions": {
          "includePaths": ["node_modules"]
        }
      },
      "configurations": {
        "production": {
          "budgets": [
            { "type": "initial", "maximumWarning": "1mb", "maximumError": "2mb" }
          ],
          "outputHashing": "all",
          "fileReplacements": [
            { "replace": "apps/applicant-portal/src/environments/environment.ts", "with": "apps/applicant-portal/src/environments/environment.prod.ts" }
          ],
          "optimization": { "scripts": true, "styles": { "minify": true }, "fonts": true }
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "executor": "@nx/angular:dev-server",
      "configurations": {
        "production": { "buildTarget": "applicant-portal:build:production" },
        "development": { "buildTarget": "applicant-portal:build:development" }
      },
      "defaultConfiguration": "development"
    },
    "test": {
      "executor": "@nx/angular:karma",
      "options": {
        "polyfills": ["zone.js", "zone.js/testing"],
        "tsConfig": "apps/applicant-portal/tsconfig.spec.json",
        "karmaConfig": "apps/applicant-portal/karma.conf.js",
        "inlineStyleLanguage": "scss",
        "styles": ["apps/applicant-portal/src/styles.scss"],
        "assets": [
          "apps/applicant-portal/src/favicon.ico",
          "apps/applicant-portal/src/assets/i18n",
          "apps/applicant-portal/src/assets/images"
        ]
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["apps/applicant-portal/**/*.ts", "apps/applicant-portal/**/*.html"]
      }
    }
  }
}