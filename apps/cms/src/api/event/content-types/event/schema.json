{
  "kind": "collectionType",
  "collectionName": "events",
  "info": {
    "singularName": "event",
    "pluralName": "events",
    "displayName": "Event",
    "description": "AVGC-XR events, workshops, conferences and campaigns"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "maxLength": 255,
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true,
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "description": {
      "type": "richtext",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "eventDate": {
      "type": "datetime",
      "required": true,
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "endDate": {
      "type": "datetime",
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "location": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "registrationUrl": {
      "type": "string",
      "regex": "^https?://.+",
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "capacity": {
      "type": "integer",
      "min": 0,
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "bannerImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"],
      "pluginOptions": { "i18n": { "localized": false } }
    }
  }
}
