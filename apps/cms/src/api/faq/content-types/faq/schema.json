{
  "kind": "collectionType",
  "collectionName": "faqs",
  "info": {
    "singularName": "faq",
    "pluralName": "faqs",
    "displayName": "FAQ",
    "description": "Frequently asked questions for the AVGC-XR portal"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "question": {
      "type": "string",
      "required": true,
      "maxLength": 500,
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "answer": {
      "type": "richtext",
      "required": true,
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "category": {
      "type": "enumeration",
      "enum": ["general", "schemes", "eligibility", "application", "technical"],
      "required": true,
      "default": "general",
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "order": {
      "type": "integer",
      "default": 0,
      "pluginOptions": { "i18n": { "localized": false } }
    }
  }
}
