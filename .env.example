# ══════════════════════════════════════════════════════════════
# Tamil Nadu AVGC-XR Portal — Environment Configuration
# ══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════

# ─── Application ────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev
APP_BASE_URL=http://localhost
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:4201,http://localhost:4202

# ─── PostgreSQL Database ────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=avgcxr_portal
DB_USER=avgcxr_user
DB_PASSWORD=change_me_in_production
PGBOUNCER_PORT=6432

# ─── Redis (Session Store + Cache) ──────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_in_production

# ─── RabbitMQ (Message Queue) ───────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=avgcxr_rmq_user
RABBITMQ_PASS=avgcxr_rmq_password
RABBITMQ_VHOST=/avgcxr
RABBITMQ_MANAGEMENT_PORT=15672

# ─── Elasticsearch (Search) ─────────────────────────────────────
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200

# ─── MinIO (File Storage) ───────────────────────────────────────
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=change_me_in_production
MINIO_SECRET_KEY=change_me_in_production
MINIO_BUCKET=application-documents

# ─── JWT Authentication ─────────────────────────────────────────
JWT_SECRET=generate-a-256-bit-secret-here-use-openssl-rand-base64-32
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ─── Strapi CMS ─────────────────────────────────────────────────
STRAPI_URL=http://cms:1337
STRAPI_API_TOKEN=change_me_in_production

# ─── SMS Gateway ────────────────────────────────────────────────
SMS_GATEWAY_URL=https://api.msg91.com/v5/flow/
SMS_GATEWAY_KEY=change_me_in_production
SMS_SENDER_ID=AVGCXR
SMS_TEMPLATE_ID=change_me_template_id

# ─── Email (SMTP) ───────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=noreply@elcot.tn.gov.in
EMAIL_PASSWORD=change_me_in_production
EMAIL_FROM=AVGC-XR Portal <noreply@elcot.tn.gov.in>

# ─── Flowable BPMN ──────────────────────────────────────────────
FLOWABLE_ADMIN_USER=admin
FLOWABLE_ADMIN_PASSWORD=change_me_in_production

# ─── File Upload ────────────────────────────────────────────────
FILE_UPLOAD_MAX_SIZE=52428800
FILE_UPLOAD_ALLOWED_TYPES=application/pdf,image/jpeg,image/png,image/webp

# ─── VAPT ────────────────────────────────────────────────────────
VAPT_SCAN_ENABLED=false
